---
import Layout from "../../layouts/Layout.astro";

// Temporary static content (replace later with CMS)
const title = "CBSE CLASS XII RESULT 2024–25 Announced";
const date = "May 16, 2025";
const image = "/Images/Campus/McsEntry.JPG";
const content = `
We are proud to announce the outstanding performance of our students in the CBSE Class XII Board Exams 2024–25. Our students have once again displayed remarkable dedication, discipline, and academic excellence.

🎓 **100% Result**  
🏅 **Top Scorer:** 98.6%  
📚 **Subject toppers across Science, Commerce & Humanities streams**

Beyond marks, this milestone reflects the collective hard work of our students, the constant support of parents, and the commitment of our highly qualified faculty.

The school extends heartfelt congratulations to all achievers and wishes them the best for their future endeavors.
`;
---

<Layout title={title}>

<main class="w-full pt-10 sm:pt-16 lg:pt-20 pb-24">
  
  <!-- Breadcrumb -->
  <nav class="max-w-5xl mx-auto px-6 text-sm text-gray-500 mb-6 flex gap-2">
    <a href="/" class="hover:text-primary">Home</a>
    <span>/</span>
    <a href="/news-events" class="hover:text-primary">News & Events</a>
    <span>/</span>
    <span class="text-gray-800">{title}</span>
  </nav>

  <!-- Title Section -->
  <header class="max-w-5xl mx-auto px-6 text-center">
    <h1 class="text-3xl sm:text-4xl font-playpen text-gray-900 mb-4 leading-snug">
      {title}
    </h1>

    <p class="text-gray-600 font-inter text-sm flex justify-center items-center gap-2">
      <img src="/Images/Doodles/Calendar.png" alt="calendar" class="w-5 h-5 opacity-70"/>
      {date}
    </p>
  </header>

  <!-- Featured Image -->
  <div class="max-w-5xl mx-auto px-6 my-10">
    <div class="rounded-3xl overflow-hidden shadow-md">
      <img src={image} alt={title} class="w-full h-[350px] sm:h-[450px] object-cover"/>
    </div>
  </div>

  <!-- Main Article -->
  <article class="max-w-4xl mx-auto px-6 text-lg leading-relaxed text-gray-800 font-inter prose prose-sm sm:prose-base">
    <p set:html={content}></p>

    <!-- Highlight Box -->
    <div class="mt-10 p-6 sm:p-8 bg-yellow-50 border-l-4 border-yellow-400 rounded-xl shadow-sm">
      <h3 class="text-lg font-semibold text-gray-900 mb-2 font-poppins">
        🔔 Next Steps for Students
      </h3>
      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li>Collect digital certificates via official CBSE portal</li>
        <li>Apply for migration and character certificates (if required)</li>
        <li>Connect with our counselors for higher studies guidance</li>
      </ul>
    </div>
  </article>

  <!-- Gallery Section -->
  <section class="max-w-5xl mx-auto px-6 mt-16">
    <h3 class="text-2xl font-poppins font-semibold text-gray-900 mb-6">
      Highlights from the Celebration 🎉
    </h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {Array.from({ length: 6 }).map((_, i) => (
        <div class="rounded-xl overflow-hidden shadow hover:shadow-md transition cursor-pointer">
          <img src={`/Images/Campus/McsEntry.JPG`} class="w-full h-48 object-cover" alt="gallery"/>
        </div>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t my-20 max-w-5xl mx-auto opacity-30"></div>

  <!-- Back Button -->
  <div class="text-center">
    <a href="/news-events" class="inline-block px-6 py-3 rounded-full bg-primary text-white hover:bg-primarydark transition font-outfit shadow">
      ← Back to News & Events
    </a>
  </div>

</main>

</Layout>

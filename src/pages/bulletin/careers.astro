---
import Layout from '../../layouts/Layout.astro';
import CareersHero from '../../components/sections/bulletinpage/CareersHero';
import Careers from '../../components/sections/bulletinpage/Careers';
---

<Layout
  title="Careers at MCS | Faculty Development | Join Our Team of Educators & Staff | MCS Pathankot | Montessori Cambridge School | Top Boarding School in Pathankot, Punjab, North India"
  description="Explore teaching and adminstrative job opportunities at MCS. Join a dynamic environment dedicated to academic excellence, innovation, and nurturing future leaders."
  pubDate={new Date()}
  >
  <main>
    <CareersHero client:load />
    <Careers client:load />
  </main>

---
import Layout from '../../layouts/Layout.astro';
import CircularsHero from '../../components/sections/bulletinpage/CircularsHero';
import Circulars from '../../components/sections/bulletinpage/Circulars';
---

<Layout
  title="Circulars & Announcements | MCS Pathankot | Montessori Cambridge School | Top Boarding School in Pathankot, Punjab, North India"
  description="Stay updated with the latest school circulars from MCS, including academic notices, events, holidays, and important announcements for students and parents."
  pubDate={new Date()}
  >
  <main>
    <CircularsHero client:load />
    <Circulars client:load />
  </main>

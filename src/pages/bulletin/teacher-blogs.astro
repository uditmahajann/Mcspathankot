---
import BlogList from "../../components/blogs/BlogList"
import { teacherPosts } from "../../components/blogs/blog"

const posts = teacherPosts
---

<html lang="en">
  <head>
    <title>Teacher Blogs | School</title>
    <meta name="description" content="Teaching insights, classroom strategies, and reflections from our faculty." />
  </head>
  <body class="bg-white">
    <main>
      <section class="relative overflow-hidden bg-gradient-to-b from-indigo-50 to-white">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
              Teacher Blogs
            </h1>
            <p class="mt-4 text-lg text-gray-600">
              Practical ideas, stories, and research-informed strategies from our teachers’ classrooms.
            </p>
          </div>
        </div>
      </section>

      <BlogList
        client:load
        heading="Latest from Faculty"
        description="Explore fresh perspectives and classroom-tested approaches."
        posts={posts}
        accent="teacher"
      />
    </main>
  </body>
</html>

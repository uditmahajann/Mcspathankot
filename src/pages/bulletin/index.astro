---
import Layout from '../../layouts/Layout.astro';
import BulletinHero from '../../components/sections/bulletinpage/BulletinHero';
import Bulletin from '../../components/sections/bulletinpage/Bulletin';
import UpcomingEvents from '../../components/sections/bulletinpage/UpcomingEvents';
import PressRelease from '../../components/sections/bulletinpage/PressRelease';
---

<Layout
  title="Krityam | Build Fast. Scale Smart. Launch Better."
  description="From MVP to full-scale apps, Krityam builds high-performance digital products for startups and enterprises. We help businesses build MVPs, scale apps, and deliver full-stack digital experiences with speed and precision."
  pubDate={new Date()}
  >
  <main>
    <BulletinHero client:load />
    <Bulletin client:load />
    <UpcomingEvents client:load />
    <PressRelease client:load />
  </main>
